# =============================================================================
# Spookfish.ai - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------

# AWS Region (e.g., us-east-1, us-west-2, eu-west-1)
NEXT_PUBLIC_AWS_REGION=your-aws-region

# AWS Cognito User Pool ID (format: us-east-1_xxxxxxxxx)
# You'll get this after deploying the SAM template
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your-user-pool-id

# AWS Cognito App Client ID (alphanumeric string)
# You'll get this after deploying the SAM template
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-client-id

# API Gateway URL (format: https://xxxxxxxxxx.execute-api.region.amazonaws.com/prod)
# You'll get this after deploying the SAM template
NEXT_PUBLIC_API_GATEWAY_URL=your-api-gateway-url

# -----------------------------------------------------------------------------
# Google Maps API
# -----------------------------------------------------------------------------

# Google Maps JavaScript API Key
# Required APIs: Maps JavaScript API, Places API (optional)
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# S3 Storage
# -----------------------------------------------------------------------------

# S3 Bucket URL for airline logos
# Format: https://your-bucket-name.s3.amazonaws.com
# or CloudFront URL: https://xxxxxx.cloudfront.net
NEXT_PUBLIC_AIRLINE_LOGOS_BUCKET=your-s3-bucket-url

# -----------------------------------------------------------------------------
# Optional Configuration
# -----------------------------------------------------------------------------

# Application name (for display purposes)
NEXT_PUBLIC_APP_NAME=Spookfish.ai

# Default refresh interval (seconds, 10-45)
NEXT_PUBLIC_DEFAULT_REFRESH_INTERVAL=30

# Default search radius (miles)
NEXT_PUBLIC_DEFAULT_SEARCH_RADIUS=10

# Enable debug mode (true/false)
NEXT_PUBLIC_DEBUG_MODE=false
